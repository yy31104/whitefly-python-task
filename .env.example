POSTGRES_DB=whitefly
POSTGRES_USER=whitefly
POSTGRES_PASSWORD=whitefly

APP_ENV=development
SECRET_KEY=replace-with-strong-random-secret
ENABLE_SUBMISSIONS_PAGE=true

DATABASE_URL=postgresql+psycopg2://whitefly:whitefly@postgres:5432/whitefly
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
RATE_LIMIT_POST_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60
